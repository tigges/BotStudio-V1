# ─── BotStudio API — environment variables ───────────────────────────────────
# Copy to .env and fill in your values

PORT=3001
NODE_ENV=development

# ─── Supabase (storage + auth) ────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # service role key (not anon)
JWT_SECRET=your-jwt-secret-min-32-chars-change-this

# ─── LLM providers (at least one required) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
GEMINI_API_KEY=AIzaSy...
OPENAI_API_KEY=sk-...       # optional — for embeddings / RAG

# ─── Google Calendar ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:3001/api/calendar/callback

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=Coco <bookings@yourdomain.com>

# ─── CORS (comma-separated allowed origins) ──────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://tigges.github.io,https://your-salon-domain.com
